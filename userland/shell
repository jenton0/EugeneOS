// === 3. ВІКОННА ПІДСИСТЕМА РЕНДЕРУ ===
#define WIN_W 500
#define WIN_H 350
uint32_t win_buffer[WIN_W * WIN_H];

void win_draw_rect(uint32_t x, uint32_t y, uint32_t w, uint32_t h, uint32_t color) {
    for (uint32_t iy = y; iy < y + h; iy++) {
        for (uint32_t ix = x; ix < x + w; ix++) {
            if (ix < WIN_W && iy < WIN_H) win_buffer[iy * WIN_W + ix] = color;
        }
    }
}

// Малює символ ПРЯМО В БУФЕР ВІКНА!
void win_draw_char(char c, uint32_t x, uint32_t y, uint32_t color) {
    int idx = toupper(c) - 32;
    if (idx < 0 || idx > 63) idx = 0; // Невідомі символи малюємо як пробіл
    
    for (int cy = 0; cy < 8; cy++) {
        uint8_t row = font8x8[idx][cy];
        for (int cx = 0; cx < 8; cx++) {
            if ((row >> (7 - cx)) & 1) {
                if (x + cx < WIN_W && y + cy < WIN_H) {
                    win_buffer[(y + cy) * WIN_W + (x + cx)] = color;
                }
            }
        }
    }
}

// Малює рядок в буфер вікна
void win_draw_string(char* text, uint32_t x, uint32_t y, uint32_t color) {
    uint32_t cx = x;
    for (int i = 0; text[i] != '\0'; i++) {
        win_draw_char(text[i], cx, y, color);
        cx += 9; // Відступ між літерами
    }
}

// === 4. ТОЧКА ВХОДУ (GUI EVENT LOOP) ===
void _start() {
    clear_screen();
    init_heap(); 

    uint32_t win_x = 100, win_y = 50;
    
    // Стан миші та перетягування
    uint32_t mx, my, mclick;
    int is_dragging = 0;
    uint32_t drag_off_x = 0, drag_off_y = 0;

    // Дані консолі
    char cmd_buffer[64] = {0};
    int cmd_len = 0;
    char history_log[12][64] = {0}; 
    int log_count = 0;

    // Прапорці оптимізації
    int text_changed = 1; // Чи треба перемалювати текст усередині буфера?
    int win_moved = 1;    // Чи треба викинути буфер на екран?

    strcpy(history_log[log_count++], "EUGENE OS GUI SHELL V3.0");
    strcpy(history_log[log_count++], "TYPE 'HELP' FOR COMMANDS.");

    while (1) {
        // --- 1. ОБРОБКА МИШІ ---
        get_mouse(&mx, &my, &mclick);

        if (mclick == 1) { 
            if (!is_dragging) {
                // Перевіряємо клік по заголовку
                if (mx >= win_x && mx <= win_x + WIN_W && my >= win_y && my <= win_y + 24) {
                    is_dragging = 1;
                    drag_off_x = mx - win_x; drag_off_y = my - win_y;
                }
            } else {
                // Вікно рухається! Оновлюємо координати
                if (win_x != mx - drag_off_x || win_y != my - drag_off_y) {
                    win_x = mx - drag_off_x; win_y = my - drag_off_y;
                    win_moved = 1; 
                }
            }
        } else {
            is_dragging = 0;
        }

        // --- 2. ОБРОБКА КЛАВІАТУРИ ---
        uint64_t key = get_key();
        if (key > 0 && key < 0x80) {
            
            if (key == 0x1C) { // ENTER
                cmd_buffer[cmd_len] = '\0';
                
                // Зберігаємо команду в лог (скролінг історії)
                if (log_count >= 12) {
                    for(int i=0; i<11; i++) strcpy(history_log[i], history_log[i+1]);
                    log_count = 11;
                }
                
                char full_cmd[80] = "C-SHELL:/> ";
                strcat(full_cmd, cmd_buffer);
                strcpy(history_log[log_count++], full_cmd);

                // ПАРСЕР КОМАНД
                if (strcmp(cmd_buffer, "HELP") == 0) {
                    strcpy(history_log[log_count++], "CMD: HELP, CLEAR, BENCHMARK, EXIT");
                } 
                else if (strcmp(cmd_buffer, "CLEAR") == 0) {
                    log_count = 0;
                }
                else if (strcmp(cmd_buffer, "BENCHMARK") == 0) {
                    strcpy(history_log[log_count++], "BENCHMARK: OK (VFS NOT LINKED)");
                }
                else if (strcmp(cmd_buffer, "EXIT") == 0) {
                    clear_screen(); 
                    syscall(0,0,0); // Exit
                }
                else if (cmd_len > 0) {
                    strcpy(history_log[log_count++], "UNKNOWN COMMAND");
                }
                
                cmd_len = 0;
                cmd_buffer[0] = '\0';
                text_changed = 1;

            } else if (key == 0x0E) { // BACKSPACE
                if (cmd_len > 0) { 
                    cmd_buffer[--cmd_len] = '\0'; 
                    text_changed = 1; 
                }
            } else { // Звичайна літера
                char c = scancodes[key];
                if (c != 0 && cmd_len < 60) {
                    cmd_buffer[cmd_len++] = c;
                    cmd_buffer[cmd_len] = '\0';
                    text_changed = 1;
                }
            }
        }

        // --- 3. ВНУТРІШНЄ МАЛЮВАННЯ (Тільки якщо ввели літеру) ---
        if (text_changed) {
            // Малюємо каркас вікна
            win_draw_rect(0, 0, WIN_W, WIN_H, 0x00000000);       // Рамка
            win_draw_rect(2, 2, WIN_W-4, WIN_H-4, 0x00C0C0C0);   // Фон
            win_draw_rect(2, 2, WIN_W-4, 24, 0x000000AA);        // Синій заголовок
            
            win_draw_string("EUGENE OS: GUI SUBSYSTEM", 10, 8, 0x00FFFFFF);

            // Малюємо історію
            uint32_t text_y = 35;
            for (int i = 0; i < log_count; i++) {
                win_draw_string(history_log[i], 10, text_y, 0x00000000); // Чорний текст
                text_y += 20;
            }

            // Малюємо поточний ввід
            char prompt[100] = "C-SHELL:/> ";
            strcat(prompt, cmd_buffer);
            strcat(prompt, "_"); // Курсор
            win_draw_string(prompt, 10, text_y, 0x00AA0000); // Синій текст
            
            text_changed = 0;
            win_moved = 1; // Якщо ми змінили пікселі всередині, треба викинути на екран
        }

        // --- 4. КОМПОЗИЦІЯ ЕКРАНА (Тільки якщо рухали вікно або вводили текст) ---
        if (win_moved) {
            clear_screen(); // Очищаємо залишки старого вікна
            blit_buffer(win_buffer, win_x, win_y, WIN_W, WIN_H); // Викидаємо вікно!
            win_moved = 0;
        }
    }
}
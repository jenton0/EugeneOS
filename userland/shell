// === 1. СИСКОЛ МИШІ ===
// Додаємо сюди, щоб ти не міняв свій stdlib.h
static inline void get_mouse(uint32_t* x, uint32_t* y, uint32_t* click) {
    uint64_t mx, my, mc;
    __asm__ volatile (
        "int $0x80"
        : "=c"(mx), "=d"(my), "=8"(mc)
        : "a"(11)
        : "memory"
    );
    *x = (uint32_t)mx; *y = (uint32_t)my; *click = (uint32_t)mc;
}

